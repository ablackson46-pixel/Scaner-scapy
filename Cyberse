class WebVulnerabilityScanner:
    """Scanner de vulnérabilités web (XSS, SQLi, etc.)"""
    
    def __init__(self, base_url):
        self.base_url = base_url
        self.vulnerabilities = []
        self.session = requests.Session()
        self.session.headers.update({
            'User-Agent': 'CyberSecScanner/1.0 (Security Audit Tool)'
        })
    
    def scan_xss(self, params_to_test=None):
        """Détection de vulnérabilités XSS"""
        logger.info(f"[*] Scan XSS sur {self.base_url}")
        
        xss_payloads = [
            "<script>alert('XSS')</script>",
            "<img src=x onerror=alert('XSS')>",
            "javascript:alert('XSS')",
            "<svg onload=alert('XSS')>",
            "'\"><script>alert(String.fromCharCode(88,83,83))</script>"
        ]
        
        vulnerabilities_found = []
        
        try:
            # Test sur les paramètres GET
            parsed = urlparse(self.base_url)
            
            for payload in xss_payloads:
                test_url = f"{self.base_url}?test={payload}"
                
                try:
                    response = self.session.get(test_url, timeout=5)
                    
                    if payload in response.text:
                        vuln = {
                            'type': 'XSS (Cross-Site Scripting)',
                            'severity': 'HIGH',
                            'url': test_url,
                            'payload': payload,
                            'description': 'Injection de script détectée - le payload est reflété dans la réponse',
                            'remediation': 'Encoder/échapper toutes les entrées utilisateur, utiliser Content Security Policy',
                            'timestamp': datetime.now().isoformat()
                        }
                        vulnerabilities_found.append(vuln)
                        logger.warning(f"[!] XSS trouvé: {test_url}")
                        break  # Un seul exemple suffit par URL
                        
                except requests.exceptions.RequestException as e:
                    logger.debug(f"Erreur requête XSS: {e}")
                    continue
            
            self.vulnerabilities.extend(vulnerabilities_found)
            return vulnerabilities_found
            
        except Exception as e:
            logger.error(f"[!] Erreur scan XSS: {e}")
            return []
    
    def scan_sql_injection(self):
        """Détection de vulnérabilités SQL Injection"""
        logger.info(f"[*] Scan SQL Injection sur {self.base_url}")
        
        sql_payloads = [
            "' OR '1'='1",
            "' OR '1'='1' --",
            "' OR '1'='1' /*",
            "admin' --",
            "' UNION SELECT NULL--",
            "1' AND '1'='1",
            "1' AND '1'='2"
        ]
        
        sql_errors = [
            "sql syntax",
            "mysql_fetch",
            "warning: mysql",
            "unclosed quotation mark",
            "quoted string not properly terminated",
            "ora-01756",
            "sqlite3.operationalerror",
            "postgresql"
        ]
        
        vulnerabilities_found = []
        
        try:
            for payload in sql_payloads:
                test_url = f"{self.base_url}?id={payload}"
                
                try:
                    response = self.session.get(test_url, timeout=5)
                    response_lower = response.text.lower()
                    
                    # Détection d'erreurs SQL
                    for error in sql_errors:
                        if error in response_lower:
                            vuln = {
                                'type': 'SQL Injection',
                                'severity': 'CRITICAL',
                                'url': test_url,
                                'payload': payload,
                                'description': f'Erreur SQL détectée: {error}',
                                'remediation': 'Utiliser des requêtes préparées (prepared statements), valider et échapper les entrées',
                                'timestamp': datetime.now().isoformat()
                            }
                            vulnerabilities_found.append(vuln)
                            logger.warning(f"[!] SQLi trouvé: {test_url}")
                            break
                    
                    if vulnerabilities_found:
                        break  # Un exemple suffit
                        
                except requests.exceptions.RequestException as e:
                    logger.debug(f"Erreur requête SQLi: {e}")
                    continue
            
            self.vulnerabilities.extend(vulnerabilities_found)
            return vulnerabilities_found
            
        except Exception as e:
            logger.error(f"[!] Erreur scan SQLi: {e}")
            return []
    
    def scan_full_website(self):
        """Scan complet du site web"""
        logger.info(f"[*] Scan complet de {self.base_url}")
        
        results = {
            'url': self.base_url,
            'timestamp': datetime.now().isoformat(),
            'vulnerabilities': []
        }
        
        # Headers de sécurité
        try:
            response = self.session.get(self.base_url, timeout=5)
            security_headers = {
                'X-Frame-Options': 'Clickjacking protection',
                'X-Content-Type-Options': 'MIME type sniffing protection',
                'Strict-Transport-Security': 'HTTPS enforcement',
                'Content-Security-Policy': 'XSS protection',
                'X-XSS-Protection': 'XSS filter'
            }
            
            for header, description in security_headers.items():
                if header not in response.headers:
                    results['vulnerabilities'].append({
                        'type': 'Missing Security Header',
                        'severity': 'MEDIUM',
                        'header': header,
                        'description': f'En-tête {header} manquant ({description})',
                        'remediation': f'Ajouter l\'en-tête {header} dans la configuration du serveur'
                    })
        
        except Exception as e:
            logger.error(f"[!] Erreur analyse headers: {e}")
        
        # Scan XSS
        xss_vulns = self.scan_xss()
        results['vulnerabilities'].extend(xss_vulns)
        
        # Scan SQLi
        sqli_vulns = self.scan_sql_injection()
        results['vulnerabilities'].extend(sqli_vulns)
        
        with results_lock:
            scan_results['web'].append(results)
        
        logger.info(f"[+] Scan terminé: {len(results['vulnerabilities'])} vulnérabilités trouvées")
        return results

