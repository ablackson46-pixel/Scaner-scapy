def send_custom_packets(target_ip, packet_type="icmp", count=10, port=80):
    """Envoie des paquets personnalisés vers une IP"""
    logger.info(f"[*] Envoi de {count} paquets {packet_type} vers {target_ip}")
    
    results = {
        'target': target_ip,
        'type': packet_type,
        'count': count,
        'responses': 0,
        'timestamp': datetime.now().isoformat()
    }
    
    try:
        if packet_type.lower() == "icmp":
            # Ping ICMP
            ans, unans = sr(IP(dst=target_ip)/ICMP(), timeout=2, verbose=False, retry=0)
            results['responses'] = len(ans)
            results['status'] = 'Host is up' if ans else 'Host is down'
            
        elif packet_type.lower() == "tcp":
            # TCP SYN scan
            ans, unans = sr(IP(dst=target_ip)/TCP(dport=port, flags="S"), 
                          timeout=2, verbose=False, retry=0)
            results['responses'] = len(ans)
            results['port'] = port
            
            if ans:
                for sent, received in ans:
                    if received.haslayer(TCP):
                        if received[TCP].flags == 0x12:  # SYN-ACK
                            results['status'] = f'Port {port} is open'
                        elif received[TCP].flags == 0x14:  # RST-ACK
                            results['status'] = f'Port {port} is closed'
        
        elif packet_type.lower() == "udp":
            # UDP probe
            ans, unans = sr(IP(dst=target_ip)/UDP(dport=port), 
                          timeout=2, verbose=False, retry=0)
            results['responses'] = len(ans)
            results['port'] = port
        
        with results_lock:
            scan_results['packets'].append(results)
        
        logger.info(f"[+] Paquets envoyés: {results['responses']}/{count} réponses")
        return results
        
    except Exception as e:
        logger.error(f"[!] Erreur envoi paquets: {e}")
        return {'error': str(e)}

