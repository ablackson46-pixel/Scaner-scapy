def generate_report(output_file="rapport_securite.json"):
    """Génère un rapport complet au format JSON"""
    logger.info(f"[*] Génération du rapport: {output_file}")
    
    report = {
        'metadata': {
            'tool': 'CyberSec Scanner',
            'version': '1.0',
            'generated_at': datetime.now().isoformat(),
            'scan_duration': 'N/A'
        },
        'wifi_networks': wifi_networks,
        'web_vulnerabilities': scan_results['web'],
        'packet_injection': scan_results['deauth'],
        'custom_packets': scan_results['packets'],
        'summary': {
            'total_wifi_networks': len(wifi_networks),
            'total_vulnerabilities': sum(len(r.get('vulnerabilities', [])) for r in scan_results['web']),
            'critical_vulnerabilities': sum(
                1 for r in scan_results['web'] 
                for v in r.get('vulnerabilities', []) 
                if v.get('severity') == 'CRITICAL'
            )
        }
    }
    
    # Sauvegarder le rapport
    output_path = f"/home/claude/{output_file}"
    try:
        with open(output_path, 'w', encoding='utf-8') as f:
            json.dump(report, f, indent=2, ensure_ascii=False)
        
        logger.info(f"[+] Rapport généré: {output_path}")
        vulnerability_reports.append(output_path)
        return output_path
        
    except Exception as e:
        logger.error(f"[!] Erreur génération rapport: {e}")
        return None

