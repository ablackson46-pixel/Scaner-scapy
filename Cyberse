def scan_wifi_networks(interface="wlan0"):
    """
    Scan des réseaux WiFi disponibles
    Nécessite des privilèges root et une interface en mode monitor
    """
    logger.info(f"[*] Démarrage du scan WiFi sur {interface}")
    global wifi_networks
    
    try:
        # Vérifier si l'interface existe
        if not os.path.exists(f"/sys/class/net/{interface}"):
            logger.error(f"[!] Interface {interface} introuvable")
            return []
        
        networks = {}
        
        def packet_handler(pkt):
            if pkt.haslayer(Dot11Beacon):
                bssid = pkt[Dot11].addr2
                ssid = pkt[Dot11Elt].info.decode('utf-8', errors='ignore')
                
                try:
                    stats = pkt[Dot11Beacon].network_stats()
                    channel = int(ord(pkt[Dot11Elt:3].info))
                    crypto = set()
                    
                    # Détection du type de chiffrement
                    if pkt.haslayer(Dot11Elt):
                        cap = pkt.sprintf("{Dot11Beacon:%Dot11Beacon.cap%}")
                        if "privacy" in cap.lower():
                            if pkt.haslayer(RSN):
                                crypto.add("WPA2")
                            else:
                                crypto.add("WEP")
                    
                    signal = pkt.dBm_AntSignal if hasattr(pkt, 'dBm_AntSignal') else -100
                    
                    networks[bssid] = {
                        'ssid': ssid if ssid else "<Hidden>",
                        'bssid': bssid,
                        'channel': channel,
                        'crypto': list(crypto) if crypto else ["Open"],
                        'signal': signal,
                        'timestamp': datetime.now().isoformat()
                    }
                except Exception as e:
                    logger.debug(f"Erreur parsing paquet: {e}")
        
        logger.info("[*] Écoute des beacons pendant 10 secondes...")
        sniff(iface=interface, prn=packet_handler, timeout=10, store=False)
        
        wifi_networks = list(networks.values())
        logger.info(f"[+] {len(wifi_networks)} réseaux WiFi détectés")
        return wifi_networks
        
    except PermissionError:
        logger.error("[!] Privilèges root requis pour le scan WiFi")
        return []
    except Exception as e:
        logger.error(f"[!] Erreur scan WiFi: {e}")
        return []

